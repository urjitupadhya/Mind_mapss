# MindLint Environment Configuration
# Copy this file to .env and fill in your values

# API Configuration
PORT=3001
NODE_ENV=development

# MegaLLM AI Configuration
MEGALLM_API_URL=https://api.megallm.com/v1/chat
MEGALLM_API_KEY=sk-mega-28439f3f19b55346888cc96fb7bcda033c3d1ab7ea212d12a782b5d5cf6b09ec
MEGALLM_MODEL=megallm-2.5

# Alternative: OpenAI Configuration (if using OpenAI)
# OPENAI_API_KEY=your_openai_key_here

# Database
DB_PATH=./mindlint.db

# Frontend
VITE_API_URL=http://localhost:3001

# Security
# JWT_SECRET=your_secret_key_here

# Features
ENABLE_TELEMETRY=true
ENABLE_DAEMON=true
